                android:fillColor="#FFFFFF"
                android:pathData="M12,0a4,4 0,1 1,0 8a4,4 0,1 1,0 -8M12,16a4,4 0,1 1,0 8a4,4 0,1 1,0 -8M0,8a5,5 0,1 1,0 10a5,5 0,1 1,0 -10" />
